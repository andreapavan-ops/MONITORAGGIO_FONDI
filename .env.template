# ================================
# FUND MONITOR SYSTEM - CONFIG
# ================================

# Email Configuration (Resend API — sostituisce Gmail SMTP bloccato da Railway)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_SENDER=noreply@tuodominio.com   # deve essere dominio verificato su Resend
EMAIL_RECIPIENT=andreapavan67@gmail.com

# Monitoring Schedule (ora UTC! Railway gira in UTC: 17 UTC = 18:00 ora italiana)
MONITOR_HOUR=17
MONITOR_MINUTE=0
# MONITOR_DAYS: giorni di esecuzione (1=Lun 2=Mar 3=Mer 4=Gio 5=Ven 6=Sab 7=Dom)
# Default 1-5 = dal Lunedì al Venerdì
MONITOR_DAYS=1-5

# Technical Analysis Settings
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
MA_PERIOD=15
MIN_INDICATORS_L3=2

# Dashboard
DASHBOARD_PORT=5000

# ================================
# ISTRUZIONI SETUP RESEND:
# ================================
# 1. Registrati su https://resend.com (piano gratuito: 3.000 email/mese)
# 2. Vai su "API Keys" → crea una nuova chiave
# 3. Vai su "Domains" → aggiungi e verifica il tuo dominio (es. andreapavan.tech)
#    (aggiungere record DNS TXT/MX/DKIM come indicato da Resend)
# 4. Usa un indirizzo @tuodominio.com come EMAIL_SENDER
# 5. In Railway: aggiungi RESEND_API_KEY nelle Variables del servizio
# ================================
# NOTA: EMAIL_PASSWORD non è più usato, può essere rimosso da Railway
# ================================
